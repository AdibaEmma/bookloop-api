# ============================================
# BookLoop Backend API - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Application
# ============================================
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1

# ============================================
# Database (PostgreSQL with PostGIS)
# ============================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=bookloop
DATABASE_PASSWORD=your_secure_password_here
DATABASE_NAME=bookloop_dev

# For production, use connection string:
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ============================================
# Redis (Cache & Sessions)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For production:
# REDIS_URL=redis://username:password@host:6379

# ============================================
# JWT Authentication
# ============================================
# Generate secure key: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-min-256-bits-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-256-bits-change-this
REFRESH_TOKEN_EXPIRES_IN=7d

# ============================================
# Hubtel SMS (Primary OTP Provider)
# ============================================
# Get credentials: https://developers.hubtel.com
HUBTEL_CLIENT_ID=your_hubtel_client_id
HUBTEL_CLIENT_SECRET=your_hubtel_client_secret
HUBTEL_API_BASE_URL=https://api.hubtel.com/v1
HUBTEL_SMS_FROM=BookLoop
HUBTEL_SMS_ENABLED=true

# ============================================
# Termii SMS (Fallback OTP Provider)
# ============================================
# Get API key: https://termii.com
TERMII_API_KEY=your_termii_api_key
TERMII_SENDER_ID=BookLoop
TERMII_API_BASE_URL=https://api.ng.termii.com
TERMII_SMS_ENABLED=true

# ============================================
# Cloudinary (Image Storage & CDN)
# ============================================
# Get credentials: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=bookloop_listings
CLOUDINARY_FOLDER=bookloop

# ============================================
# Mapbox (Maps & Geocoding)
# ============================================
# Get token: https://account.mapbox.com
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token
MAPBOX_SECRET_TOKEN=sk.your_mapbox_secret_token

# ============================================
# Firebase (Cloud Messaging - FCM)
# ============================================
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_firebase_private_key_here
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Alternative: Path to service account JSON file
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# ============================================
# Paystack (Payment Gateway)
# ============================================
# Get keys: https://dashboard.paystack.com/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret
PAYSTACK_CALLBACK_URL=https://api.bookloop.gh/webhooks/paystack

# ============================================
# Hubtel Payments (Mobile Money)
# ============================================
# Get credentials: https://developers.hubtel.com
HUBTEL_PAYMENT_CLIENT_ID=your_payment_client_id
HUBTEL_PAYMENT_CLIENT_SECRET=your_payment_client_secret
HUBTEL_PAYMENT_MERCHANT_ACCOUNT_NUMBER=your_merchant_number
HUBTEL_PAYMENT_WEBHOOK_URL=https://api.bookloop.gh/webhooks/hubtel

# ============================================
# Ghana Card Verification API (Optional)
# ============================================
# If using third-party Ghana Card verification service
GHANA_CARD_API_KEY=your_api_key
GHANA_CARD_API_URL=https://api.example.com/verify
GHANA_CARD_OCR_ENABLED=false

# ============================================
# Sentry (Error Tracking)
# ============================================
# Get DSN: https://sentry.io/settings/your-org/projects/
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
SENTRY_ENABLED=true
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_MAX=5
OTP_RATE_LIMIT_WINDOW_MS=3600000

# ============================================
# CORS (Cross-Origin Resource Sharing)
# ============================================
CORS_ORIGIN=http://localhost:3001,exp://192.168.1.100:8081
CORS_CREDENTIALS=true

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs

# ============================================
# Background Jobs (BullMQ)
# ============================================
BULL_QUEUE_PREFIX=bookloop
BULL_REMOVE_ON_COMPLETE=100
BULL_REMOVE_ON_FAIL=1000

# ============================================
# Email (Optional - for admin notifications)
# ============================================
# Using @nestjs-modules/mailer
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@bookloop.gh
MAIL_ENABLED=false

# ============================================
# Admin Credentials (Initial Setup)
# ============================================
# Used to create first admin user
ADMIN_PHONE=+233500000000
ADMIN_PASSWORD=change_this_secure_password
ADMIN_EMAIL=admin@bookloop.gh

# ============================================
# Feature Flags (Toggle Features)
# ============================================
FEATURE_WHATSAPP_BOT_ENABLED=false
FEATURE_DELIVERY_ENABLED=false
FEATURE_BOOST_LISTINGS_ENABLED=true
FEATURE_SERVICE_FEE_ENABLED=true
FEATURE_GHANA_CARD_REQUIRED=false

# ============================================
# Analytics (Optional)
# ============================================
# PostHog (self-hosted or cloud)
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com
POSTHOG_ENABLED=false

# ============================================
# Development Tools
# ============================================
# Swagger API Documentation
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# Database Synchronize (DANGER: Only for development)
# DO NOT enable in production - use migrations instead
DATABASE_SYNCHRONIZE=false

# Database Logging (SQL queries)
DATABASE_LOGGING=true
